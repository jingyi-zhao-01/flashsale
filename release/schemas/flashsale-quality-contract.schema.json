{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flashsale.dev/schemas/flashsale-quality-contract.schema.json",
  "title": "Flashsale Quality Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "flashsale.dev/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "FlashsaleQualityContract"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "perf"
      ],
      "properties": {
        "perf": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cadence"
          ],
          "properties": {
            "cadence": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/perfCadenceLane"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "perfCadenceLane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "invocation"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "displayName": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "pauseBeforeSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "invocation": {
          "oneOf": [
            {
              "$ref": "#/$defs/makeInvocation"
            },
            {
              "$ref": "#/$defs/pythonInvocation"
            }
          ]
        }
      }
    },
    "makeInvocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "make"
        },
        "target": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "pythonInvocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "script"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "python"
        },
        "script": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
