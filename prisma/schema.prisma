generator schema_features {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder", "multiSchema"]
  output          = "../generated/prisma_js_client"
}

generator client {
  provider                    = "prisma-client-py"
  interface                   = "sync"
  recursive_type_depth        = 5
  enable_experimental_decimal = true
  output                      = "../generated/flashsale_client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["user_service", "product_service", "order_service"]
}
